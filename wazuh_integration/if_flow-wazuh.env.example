CLICKHOUSE_URL=http://127.0.0.1:8123/
CLICKHOUSE_DATABASE=default
CLICKHOUSE_TABLE=if_flow
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=

IF_FLOW_WAZUH_ALERT_PATH=/opt/if_flow/wazuh/if_flow_alerts.jsonl
IF_FLOW_WAZUH_STATE_PATH=/opt/if_flow/wazuh/wazuh_bridge_state.json
IF_FLOW_WAZUH_POLL_SEC=30
IF_FLOW_WAZUH_TIMEOUT_SEC=10
IF_FLOW_WAZUH_BATCH_ROWS=10000
IF_FLOW_WAZUH_BYTES_THRESHOLD=1048576

IF_FLOW_WAZUH_DB_CLASSES=postgres,mysql,mssql,oracle,cassandra,cockroachdb
IF_FLOW_WAZUH_SENSITIVE_CLASSES=ldap,kerberos,vault,k8s_api
IF_FLOW_WAZUH_ROUTING_CLASSES=wireguard,bgp,bgpd,bfdd,zebra,ospfd,ospf6d,isisd,babeld,pimd,ldpd,nhrpd,eigrpd,fabricd,pathd,staticd
IF_FLOW_WAZUH_LARGE_TRANSFER_DIRECTIONS=out,transit
