IF_FLOW_JSON_PATH=/opt/if_flow/if_flow-*.jsonl
IF_FLOW_UPLOADER_STATE_PATH=/opt/if_flow/clickhouse_uploader_state.json
CLICKHOUSE_URL=http://127.0.0.1:8123/
CLICKHOUSE_DATABASE=default
CLICKHOUSE_TABLE=if_flow
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
IF_FLOW_UPLOADER_BATCH_LINES=5000
IF_FLOW_UPLOADER_BATCH_BYTES=8388608
IF_FLOW_UPLOADER_MAX_BATCHES_PER_FILE=64
IF_FLOW_UPLOADER_POLL_SEC=1
IF_FLOW_UPLOADER_TIMEOUT_SEC=10
IF_FLOW_UPLOADER_MAX_RETRIES=3
IF_FLOW_UPLOADER_RETRY_BACKOFF_SEC=1
IF_FLOW_UPLOADER_RETRY_BACKOFF_MAX_SEC=10
IF_FLOW_UPLOADER_DELETE_SENT_ROTATED=1
IF_FLOW_UPLOADER_TRUNCATE_SENT_ACTIVE=0
